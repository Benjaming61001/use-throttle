{
  "name": "@benjaming61001/use-throttle",
  "version": "1.1.1",
  "description": "A lightweight TypeScript throttle function implementation that fires on the leading edge, preserving this context and parameters.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src/",
    "lint:fix": "oxlint src/ --fix",
    "format": "oxfmt src/",
    "format:fix": "oxfmt src/ --write"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Benjaming61001/use-throttle.git"
  },
  "keywords": [
    "throttle",
    "typescript",
    "javascript",
    "util",
    "utility",
    "performance",
    "optimization",
    "event-handler",
    "rate-limiting"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Benjaming61001/use-throttle/issues"
  },
  "homepage": "https://github.com/Benjaming61001/use-throttle#readme",
  "devDependencies": {
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
